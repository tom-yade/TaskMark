{
  "name": "taskmark",
  "displayName": "TaskMark",
  "description": "Schedule and Task Management with Markdown and Calendar/Timeline Views",
  "version": "1.2.0",
  "icon": "media/icon.png",
  "publisher": "Yadecode",
  "repository": {
    "type": "git",
    "url": "https://github.com/tom-yade/taskmark.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "taskmark.openView",
        "title": "TaskMark: Open View",
        "icon": "$(open-preview)"
      }
    ],
    "keybindings": [
      {
        "command": "taskmark.openView",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == tmd"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "taskmark.openView",
          "when": "editorLangId == tmd",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "tmd",
        "aliases": [
          "TaskMark",
          "tmd"
        ],
        "extensions": [
          ".tmd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tmd",
        "scopeName": "source.tmd",
        "path": "./syntaxes/tmd.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "TaskMark",
      "properties": {
        "taskmark.tagColors": {
          "type": "object",
          "default": {},
          "description": "Custom color mapping for tags (e.g. {\"meeting\": \"#ff0000\"})"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:unit": "npm run compile && mocha --ui tdd out/test/suite/parser.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/vscode": "^1.115.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.57.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.4.5"
  }
}
